{
  "$schema": "https://tree-sitter.github.io/tree-sitter/assets/schemas/grammar.schema.json",
  "name": "kanata",
  "rules": {
    "source_file": {
      "type": "REPEAT",
      "content": {
        "type": "SYMBOL",
        "name": "_form"
      }
    },
    "_form": {
      "type": "CHOICE",
      "members": [
        {
          "type": "SYMBOL",
          "name": "list"
        },
        {
          "type": "SYMBOL",
          "name": "string"
        },
        {
          "type": "SYMBOL",
          "name": "raw_string"
        },
        {
          "type": "SYMBOL",
          "name": "number"
        },
        {
          "type": "SYMBOL",
          "name": "variable_reference"
        },
        {
          "type": "SYMBOL",
          "name": "alias_reference"
        },
        {
          "type": "SYMBOL",
          "name": "identifier"
        }
      ]
    },
    "list": {
      "type": "SEQ",
      "members": [
        {
          "type": "STRING",
          "value": "("
        },
        {
          "type": "REPEAT",
          "content": {
            "type": "SYMBOL",
            "name": "_form"
          }
        },
        {
          "type": "STRING",
          "value": ")"
        }
      ]
    },
    "string": {
      "type": "TOKEN",
      "content": {
        "type": "SEQ",
        "members": [
          {
            "type": "STRING",
            "value": "\""
          },
          {
            "type": "PATTERN",
            "value": "[^\"\\n]*"
          },
          {
            "type": "STRING",
            "value": "\""
          }
        ]
      }
    },
    "number": {
      "type": "PATTERN",
      "value": "-?\\d+(\\.\\d+)?"
    },
    "variable_reference": {
      "type": "PATTERN",
      "value": "\\$[^\\s()\"]+"
    },
    "alias_reference": {
      "type": "PATTERN",
      "value": "@[^\\s()\"]+"
    },
    "identifier": {
      "type": "PATTERN",
      "value": "[^\\s()\"]+"
    },
    "line_comment": {
      "type": "TOKEN",
      "content": {
        "type": "PREC",
        "value": 2,
        "content": {
          "type": "SEQ",
          "members": [
            {
              "type": "STRING",
              "value": ";;"
            },
            {
              "type": "PATTERN",
              "value": "[^\\n]*"
            }
          ]
        }
      }
    },
    "block_comment": {
      "type": "TOKEN",
      "content": {
        "type": "PREC",
        "value": 2,
        "content": {
          "type": "SEQ",
          "members": [
            {
              "type": "STRING",
              "value": "#|"
            },
            {
              "type": "PATTERN",
              "value": "[^|]*\\|+([^#|][^|]*\\|+)*"
            },
            {
              "type": "STRING",
              "value": "#"
            }
          ]
        }
      }
    }
  },
  "extras": [
    {
      "type": "PATTERN",
      "value": "\\s"
    },
    {
      "type": "SYMBOL",
      "name": "line_comment"
    },
    {
      "type": "SYMBOL",
      "name": "block_comment"
    }
  ],
  "conflicts": [],
  "precedences": [],
  "externals": [
    {
      "type": "SYMBOL",
      "name": "raw_string"
    }
  ],
  "inline": [],
  "supertypes": [],
  "reserved": {}
}